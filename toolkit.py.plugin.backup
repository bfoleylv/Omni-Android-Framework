import os
import subprocess
import sys
import tkinter as tk
from tkinter import ttk, messagebox

class OmniFramework:
    def __init__(self, root):
        self.root = root
        self.root.title("Omni-Android-Framework v1.0")
        self.root.geometry("1000x650")
        self.root.configure(bg="#121212")

        # 1. PATH CONFIGURATION (The "Lower-Case" Standard)
        self.base_dir = os.path.dirname(os.path.abspath(__file__))
        self.driver_dir = os.path.join(self.base_dir, "drivers")
        self.plugin_dir = os.path.join(self.base_dir, "plugins")
        self.sensor_dir = os.path.join(self.base_dir, "sensors")

        # Ensure all directory structures are present
        for directory in [self.driver_dir, self.plugin_dir, self.sensor_dir]:
            if not os.path.exists(directory):
                os.makedirs(directory)

        # 2. UI STYLING (Dark Mode / Matrix Aesthetics)
        self.style = ttk.Style()
        self.style.theme_use('clam')
        self.style.configure("TNotebook", background="#1e1e1e", borderwidth=0)
        self.style.configure("TNotebook.Tab", background="#333333", foreground="#ffffff", padding=[10, 5])
        self.style.map("TNotebook.Tab", background=[("selected", "#00ff00")], foreground=[("selected", "#000000")])

        # 3. MAIN LAYOUT
        self.paned = ttk.PanedWindow(self.root, orient="horizontal")
        self.paned.pack(expand=True, fill="both")

        # LEFT PANEL: The Spec Sheet (Back of Phone Info)
        self.left_frame = tk.Frame(self.paned, bg="#000000", width=300)
        self.paned.add(self.left_frame)

        tk.Label(self.left_frame, text="SYSTEM DIAGNOSTICS", bg="#000000", fg="#00ff00", font=("Fixedsys", 12)).pack(pady=10)
        
        self.console = tk.Text(self.left_frame, bg="#000000", fg="#00ff00", font=("Courier", 10), insertbackground="white", bd=0)
        self.console.pack(expand=True, fill="both", padx=10, pady=5)

        # RIGHT PANEL: The Plugin Tabs
        self.right_frame = tk.Frame(self.paned, bg="#1e1e1e")
        self.paned.add(self.right_frame)

        self.notebook = ttk.Notebook(self.right_frame)
        self.notebook.pack(expand=True, fill="both", padx=5, pady=5)

        # 4. INITIALIZE CONTENT
        self.refresh_diagnostics()
        self.build_plugin_tabs()

    def refresh_diagnostics(self):
        """Scans the /sensors/ folder and displays output in the green console."""
        self.console.delete("1.0", tk.END)
        self.console.insert(tk.END, "--- SCANNING HARDWARE ---\n")
        
        if os.path.exists(self.sensor_dir):
            scripts = [f for f in os.listdir(self.sensor_dir) if f.endswith(".py")]
            for script in scripts:
                path = os.path.join(self.sensor_dir, script)
                try:
                    proc = subprocess.run([sys.executable, path], capture_output=True, text=True, timeout=2)
                    self.console.insert(tk.END, f"\n[+] {script[:-3].upper()}:\n{proc.stdout}")
                except Exception as e:
                    self.console.insert(tk.END, f"\n[!] {script[:-3].upper()}: ERROR")
        
        # Automatic refresh every 10 seconds to keep diagnostics current
        self.root.after(10000, self.refresh_diagnostics)

    def build_plugin_tabs(self):
        """Dynamically creates tabs based on folders in /plugins/."""
        if not os.path.exists(self.plugin_dir):
            return

        for folder in sorted(os.listdir(self.plugin_dir)):
            full_path = os.path.join(self.plugin_dir, folder)
            if os.path.isdir(full_path):
                tab = ttk.Frame(self.notebook)
                self.notebook.add(tab, text=folder.lower())
                
                # Add buttons for every script in this category
                for file in sorted(os.listdir(full_path)):
                    if file.endswith(".py"):
                        name = file[:-3].replace("_", " ").upper()
                        btn = ttk.Button(tab, text=name, command=lambda f=folder, s=file: self.run_tool(f, s))
                        btn.pack(pady=8, padx=20, fill="x")

    def run_tool(self, category, filename):
        """Executes the plugin and provides the driver folder path."""
        target = os.path.join(self.plugin_dir, category, filename)
        
        # Passing the driver directory as an environment variable
        env_vars = os.environ.copy()
        env_vars["OMNI_DRIVER_PAYLOAD"] = self.driver_dir
        
        try:
            subprocess.Popen([sys.executable, target], env=env_vars)
            print(f"[*] Started: {filename} from {category}")
        except Exception as e:
            messagebox.showerror("Execution Error", f"Failed to launch {filename}\n{str(e)}")

if __name__ == "__main__":
    root = tk.Tk()
    app = OmniFramework(root)
    root.mainloop()
